# Cloudflare Pages headers config
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

/
  Link: </.well-known/api-catalog>; rel="api-catalog", </.well-known/agent-skills/index.json>; rel="agent-skills-index", </llms.txt>; rel="alternate"; type="text/markdown"

/.well-known/api-catalog
  Content-Type: application/linkset+json; charset=utf-8
  Access-Control-Allow-Origin: *

/.well-known/api-catalog.json
  Content-Type: application/linkset+json; charset=utf-8
  Access-Control-Allow-Origin: *

/.well-known/agent-skills/index.json
  Content-Type: application/json; charset=utf-8
  Access-Control-Allow-Origin: *

/.well-known/agent-skills/*/SKILL.md
  Content-Type: text/markdown; charset=utf-8
  Access-Control-Allow-Origin: *

/llms.txt
  Content-Type: text/markdown; charset=utf-8

/llms-full.txt
  Content-Type: text/markdown; charset=utf-8

/index.md
  Content-Type: text/markdown; charset=utf-8

/privacy-policy.md
  Content-Type: text/markdown; charset=utf-8
